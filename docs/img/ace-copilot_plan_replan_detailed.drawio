    </mxCell>
    <mxCell id="detectors-title" value="Behavior Detectors" style="text;fontSize=11;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#c62828;spacingLeft=8;" vertex="1" parent="1">
      <mxGeometry x="40" y="274" width="160" height="18" as="geometry"/>
    </mxCell>
    <mxCell id="detectors-desc" value="errors · recoveries · patterns · user corrections · tool usage · stalls · backtracking · workflows" style="text;fontSize=9;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#c62828;" vertex="1" parent="1">
      <mxGeometry x="40" y="290" width="700" height="24" as="geometry"/>
    </mxCell>

    <!-- Arrow ReAct → Detectors -->
    <mxCell id="e-react-detect" style="endArrow=classic;strokeColor=#c62828;strokeWidth=1.5;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="react-box" target="detectors-box">
      <mxGeometry relative="1" as="geometry"/>
