    </mxCell>
    <mxCell id="react-title" value="ReAct Loop" style="text;fontSize=12;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#0d47a1;spacingLeft=8;" vertex="1" parent="1">
      <mxGeometry x="40" y="200" width="120" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="react-desc" value="reason → act → observe → reason      (single-step foundation for both planned and direct execution)" style="text;fontSize=10;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#1565c0;" vertex="1" parent="1">
      <mxGeometry x="40" y="218" width="700" height="34" as="geometry"/>
    </mxCell>

    <!-- Arrow from Plan/Execute → ReAct -->
    <mxCell id="e-plan-react" style="endArrow=classic;strokeColor=#1565c0;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="plan-box" target="react-box">
