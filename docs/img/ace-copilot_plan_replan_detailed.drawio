    <mxCell id="inject-label1" value="each step" style="text;fontSize=8;fillColor=none;strokeColor=none;fontColor=#1565c0;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="398" y="185" width="50" height="14" as="geometry"/>
    </mxCell>

    <!-- ===== BEHAVIOR DETECTORS ===== -->
    <mxCell id="detectors-box" value="" style="rounded=1;fillColor=#fce4ec;strokeColor=#c62828;strokeWidth=1.5;" vertex="1" parent="1">
