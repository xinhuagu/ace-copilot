    <!-- ===== SELF-LEARNING ENGINE ===== -->
    <mxCell id="learning-box" value="" style="rounded=1;fillColor=#fff3e0;strokeColor=#e65100;strokeWidth=1.5;" vertex="1" parent="1">
      <mxGeometry x="40" y="334" width="340" height="45" as="geometry"/>
    </mxCell>
    <mxCell id="learning-title" value="Self-Learning Engine" style="text;fontSize=11;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#e65100;spacingLeft=8;" vertex="1" parent="1">
