<mxGraphModel>
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- White background -->
    <mxCell id="bg" value="" style="rounded=0;fillColor=#FFFFFF;strokeColor=none;opacity=100;" vertex="1" parent="1">
      <mxGeometry x="0" y="0" width="780" height="580" as="geometry"/>
    </mxCell>

    <!-- Title -->
    <mxCell id="title" value="AceCopilot: Self-Learning Daemon Architecture" style="text;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#1a1a2e;" vertex="1" parent="1">
      <mxGeometry x="40" y="12" width="700" height="28" as="geometry"/>
    </mxCell>

    <!-- ===== TOP ROW: CLI → UDS → Daemon ===== -->
    <!-- CLI/REPL -->
    <mxCell id="cli" value="CLI / REPL" style="rounded=1;fillColor=#e8eaf6;strokeColor=#3949ab;fontSize=11;fontStyle=1;align=center;whiteSpace=wrap;arcSize=30;" vertex="1" parent="1">
      <mxGeometry x="40" y="55" width="100" height="36" as="geometry"/>
    </mxCell>

    <!-- UDS label -->
    <mxCell id="uds-label" value="UDS only&#xa;(no network surface)" style="text;fontSize=8;align=center;fillColor=none;strokeColor=none;fontColor=#5c6bc0;fontStyle=2;" vertex="1" parent="1">
      <mxGeometry x="150" y="55" width="100" height="36" as="geometry"/>
    </mxCell>

    <!-- Arrow CLI → Daemon -->
    <mxCell id="e-cli-daemon" style="endArrow=classic;strokeColor=#3949ab;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="cli" target="daemon-box">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Daemon Box -->
    <mxCell id="daemon-box" value="" style="rounded=1;fillColor=#f5f5f5;strokeColor=#3949ab;strokeWidth=2;" vertex="1" parent="1">
      <mxGeometry x="260" y="48" width="480" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="daemon-title" value="Persistent JVM Daemon" style="text;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#1a237e;" vertex="1" parent="1">
      <mxGeometry x="260" y="48" width="480" height="50" as="geometry"/>
    </mxCell>

    <!-- ===== PLAN → EXECUTE → REPLAN (NEW addition) ===== -->
    <mxCell id="plan-box" value="" style="rounded=1;fillColor=#fff3e0;strokeColor=#e65100;strokeWidth=2;dashed=0;" vertex="1" parent="1">
      <mxGeometry x="40" y="115" width="700" height="68" as="geometry"/>
    </mxCell>
    <mxCell id="plan-title" value="Plan → Execute → Replan" style="text;fontSize=11;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#bf360c;spacingLeft=8;" vertex="1" parent="1">
      <mxGeometry x="40" y="115" width="200" height="20" as="geometry"/>
    </mxCell>

    <!-- Plan step -->
    <mxCell id="plan-step" value="LLMTaskPlanner&#xa;Generate plan" style="rounded=1;fillColor=#ffccbc;strokeColor=#bf360c;fontSize=9;fontStyle=1;align=center;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="60" y="140" width="115" height="34" as="geometry"/>
    </mxCell>

    <!-- Execute step -->
    <mxCell id="exec-step" value="SequentialPlanExecutor&#xa;Per-step budgets" style="rounded=1;fillColor=#ffccbc;strokeColor=#bf360c;fontSize=9;fontStyle=1;align=center;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="210" y="140" width="140" height="34" as="geometry"/>
    </mxCell>

    <!-- Replan step -->
    <mxCell id="replan-step" value="AdaptiveReplanner&#xa;Revise on failure" style="rounded=1;fillColor=#ffccbc;strokeColor=#bf360c;fontSize=9;fontStyle=1;align=center;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="385" y="140" width="125" height="34" as="geometry"/>
    </mxCell>

    <!-- Checkpoint -->
    <mxCell id="checkpoint" value="Checkpoint&#xa;Crash-safe resume" style="rounded=1;fillColor=#fff9c4;strokeColor=#f57f17;fontSize=8;align=center;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="545" y="140" width="100" height="34" as="geometry"/>
    </mxCell>

    <!-- Arrow Plan → Execute -->
    <mxCell id="e-plan-exec" style="endArrow=classic;strokeColor=#bf360c;strokeWidth=1.5;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="plan-step" target="exec-step">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Arrow Execute → Replan -->
    <mxCell id="e-exec-replan" style="endArrow=classic;strokeColor=#bf360c;strokeWidth=1.5;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="exec-step" target="replan-step">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Arrow Replan → Checkpoint -->
    <mxCell id="e-replan-check" style="endArrow=classic;strokeColor=#f57f17;strokeWidth=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="replan-step" target="checkpoint">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Replan loops back to Execute (curved arrow above) -->
    <mxCell id="e-replan-back" style="endArrow=classic;strokeColor=#bf360c;strokeWidth=1.5;curved=1;exitX=0.5;exitY=0;entryX=0.5;entryY=0;dashed=1;" edge="1" parent="1" source="replan-step" target="exec-step">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="447" y="126"/>
          <mxPoint x="280" y="126"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="replan-label" value="replan" style="text;fontSize=7;fillColor=none;strokeColor=none;fontColor=#bf360c;fontStyle=2;" vertex="1" parent="1">
      <mxGeometry x="345" y="117" width="35" height="12" as="geometry"/>
    </mxCell>

    <!-- Label: new vs flat ReAct -->
    <mxCell id="plan-note" value="Unlike flat ReAct: explicit plan with visibility, structured recovery, &amp; crash safety" style="text;fontSize=8;align=right;fillColor=none;strokeColor=none;fontColor=#e65100;fontStyle=2;" vertex="1" parent="1">
      <mxGeometry x="380" y="115" width="350" height="18" as="geometry"/>
    </mxCell>

    <!-- ===== REACT LOOP ===== -->
    <mxCell id="react-box" value="" style="rounded=1;fillColor=#e3f2fd;strokeColor=#1565c0;strokeWidth=2;" vertex="1" parent="1">
